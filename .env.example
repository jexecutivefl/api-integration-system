# Database - Neon Postgres
# Set in Vercel via the Neon integration (auto-populated)
DATABASE_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Application
NEXT_PUBLIC_APP_NAME="API Integration System"
NODE_ENV="development"

# Connector Configuration (mock mode by default)
CRM_API_KEY="mock_crm_key_xxx"
CRM_BASE_URL="https://api.example-crm.com/v2"
PAYMENT_API_KEY="mock_payment_key_xxx"
PAYMENT_BASE_URL="https://api.example-payments.com/v1"
FORM_WEBHOOK_SECRET="mock_webhook_secret_xxx"
SUPPORT_API_KEY="mock_support_key_xxx"
SUPPORT_BASE_URL="https://api.example-support.com/v1"

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=30000
